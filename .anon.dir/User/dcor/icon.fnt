@font-face{font-family:'icon'; src:url('data:font/woff;base64,') format('woff'); font-weight:normal; font-style:normal;}

.font-icon{font-family:'icon';}

[class^='icon-']:before, [class*=' icon-']:before{font-family:'icon' !important; speak:none; font-style:normal; font-weight:normal; font-variant:normal; text-transform:none; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;}

